# Paperclip on Hostinger — example environment file.
#
# Copy to `.env` next to docker-compose.hostinger.yml and fill in real values:
#
#   cp docker/.env.example docker/.env
#   $EDITOR docker/.env
#
# The compose file uses `${VAR:?...}` for the two domain-specific required
# vars below (PAPERCLIP_PUBLIC_URL, PAPERCLIP_ALLOWED_HOSTNAMES), so the stack
# refuses to start if either is missing or empty. The two random secrets
# (PAPERCLIP_AGENT_JWT_SECRET, BETTER_AUTH_SECRET) are optional — if you leave
# them empty here, the `init` service generates 32 random bytes for each on
# first boot and persists them to /paperclip/.secrets/ on the paperclip-data
# volume so they survive restarts.

# ─── Required ────────────────────────────────────────────────────────────────

# Public URL the browser uses (must match what your TLS-terminating reverse
# proxy serves). Include the scheme.
PAPERCLIP_PUBLIC_URL=https://paperclip.example.com

# Comma-separated list of hostnames the server will accept Host headers for.
# Usually just the bare hostname from PAPERCLIP_PUBLIC_URL.
PAPERCLIP_ALLOWED_HOSTNAMES=paperclip.example.com

# ─── Optional secrets (auto-generated by `init` if left empty) ───────────────
#
# Each is 32 random bytes (hex). Set explicitly only if you want to control
# the value yourself (e.g. shared with another service). Generate with:
#   openssl rand -hex 32
# Whatever value `init` writes (generated or operator-provided) is persisted
# to /paperclip/.secrets/ on the paperclip-data volume; deleting that volume
# invalidates every active session and agent JWT.
PAPERCLIP_AGENT_JWT_SECRET=
BETTER_AUTH_SECRET=

# ─── Optional ────────────────────────────────────────────────────────────────

# Pin the Paperclip image to a specific tag or digest. Strongly recommended in
# production so upgrades and rollbacks are explicit.
# PAPERCLIP_IMAGE=ghcr.io/paperclipai/paperclip@sha256:...

# Override the gateway.js source. The compose file already pins a default URL
# (commit SHA) and SHA256, so leave these unset unless you are upgrading the
# gateway. When you do, set BOTH together.
# GATEWAY_JS_URL=https://raw.githubusercontent.com/mjraraujo/paperclip-proxy/<commit-sha>/proxy/bin/gateway.js
# GATEWAY_JS_SHA256=<sha256 of that file>
